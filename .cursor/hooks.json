{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/mark-architecture-dirty.ps1"
      }
    ],
    "stop": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/refresh-architecture-map.ps1"
      }
    ]
  }
}
