             <script>
    $(function() {
        bizx.cmp.ifConsent({ purposes: 'all' , vendors: 'narrative'}, function() {
            var current_time = (new Date()).getTime();
            let imageUrl = "https://io.narrative.io/?companyId=2440&id=first_party%3A41e1af71-81ad-4628-b900-69eca874d60b&id=site_name%3Asourceforge.net&id=url%3A%2Fprojects%2Ffreetengwar%2Ffiles%2F&id=pagetitle%3AFree+Tengwar+Font+Project+-++Browse+Files+at+SourceForge.net&id=vertical%3AOpen+Source+Software&id=product%3AFree+Tengwar+Font+Project&id=topics%3AFonts";
            imageUrl = imageUrl.replace(encodeURIComponent("$PAGE_TITLE"), document.title);  

            imageUrl = URL.parse(imageUrl);
            let hem = bizx.uids.getHem();
            if (hem) {
                imageUrl.searchParams.append('id', 'hem:' + hem);
            }
            imageUrl.searchParams.append('rand', current_time);

            var image = new Image();
            image.src = imageUrl.toString();
            image.style.display = "none";
            image.style.height = 0;
            image.style.width = 0;
            document.body.appendChild(image);
        });
    });
</script>
        

        
            
